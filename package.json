{
  "name": "desktop-pet",
  "version": "1.0.0",
  "description": "Pixel anime desktop pet with chat capabilities",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc && npm run copy-assets && npm run patch-pixelmaps",
    "copy-assets": "node -e \"var fs=require('fs'),p=require('path');['pet','chat'].forEach(function(d){['index.html','tts.js'].forEach(function(f){var s=p.join('src/renderer',d,f),t=p.join('dist/renderer',d,f);if(fs.existsSync(s))fs.copyFileSync(s,t)})});\" && echo Assets copied",
    "patch-pixelmaps": "node -e \"var fs=require('fs');fs.copyFileSync('assets/pixelMaps.browser.js','dist/renderer/shared/pixelMaps.js');\" && echo pixelMaps patched",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  },
  "build": {
    "appId": "com.desktop-pet.app",
    "productName": "Desktop Pet",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": ["portable", "nsis"],
      "icon": "assets/tray-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
